<?xml version="1.0" encoding="utf-8"?>
<!--
    整体结构（从上到下固定）：
    1. Toolbar（标题栏）
    2. 操作栏（关键字替换 + 六大按钮）—— 固定，不滚动
    3. 格式工具栏 —— 固定，不滚动
    4. 编辑区（支持内部滚动，编辑即实时预览）
    5. 状态栏 + 字数
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color"
    tools:context=".ui.MainActivity">

    <!-- ① Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_color"
        app:titleTextColor="@android:color/white"
        app:title="@string/app_name" />

    <!-- ② 操作栏（固定，不随编辑区滚动） -->
    <LinearLayout
        android:id="@+id/actionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- 关键字替换行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/hint_search_keyword">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearchKeyword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/hint_replace_content">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etReplaceContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReplace"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/btn_replace"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                app:backgroundTint="@color/btn_replace_color"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_find_replace"
                app:iconSize="15dp"
                app:iconPadding="2dp" />

        </LinearLayout>

        <!-- 六大功能按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpen"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/btn_open"
                android:textSize="11sp"
                android:paddingHorizontal="2dp"
                app:backgroundTint="@color/btn_replace_color"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_open_file"
                app:iconSize="14dp"
                app:iconPadding="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyAll"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/btn_copy_all"
                android:textSize="11sp"
                android:paddingHorizontal="2dp"
                app:backgroundTint="@color/btn_copy_color"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_copy"
                app:iconSize="14dp"
                app:iconPadding="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyAndClear"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/btn_copy_clear"
                android:textSize="11sp"
                android:paddingHorizontal="2dp"
                app:backgroundTint="@color/btn_copy_clear_color"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_copy_clear"
                app:iconSize="14dp"
                app:iconPadding="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="@string/btn_clear"
                android:textSize="11sp"
                android:paddingHorizontal="2dp"
                app:backgroundTint="@color/btn_clear_color"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_clear"
                app:iconSize="14dp"
                app:iconPadding="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_save"
                android:textSize="11sp"
                android:paddingHorizontal="2dp"
                app:backgroundTint="@color/btn_save_color"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_save"
                app:iconSize="14dp"
                app:iconPadding="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ③ 格式工具栏（固定，不随编辑区滚动） -->
    <LinearLayout
        android:id="@+id/editorToolbar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_toolbar"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBold"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_format_bold"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/format_bold"
            android:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btnItalic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_format_italic"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/format_italic"
            android:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btnUnderline"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_format_underline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/format_underline"
            android:tint="@color/text_primary" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/divider_color"
            android:layout_marginHorizontal="4dp" />

        <ImageButton
            android:id="@+id/btnInsertImage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_insert_photo"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/insert_image"
            android:tint="@color/text_primary" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/divider_color"
            android:layout_marginHorizontal="4dp" />

        <ImageButton
            android:id="@+id/btnPasteRich"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_content_paste"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/paste_rich"
            android:tint="@color/accent_color" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 字数统计 -->
        <TextView
            android:id="@+id/tvCharCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 字"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:paddingEnd="4dp" />

    </LinearLayout>

    <!-- ④ 编辑区（占满剩余空间，内部可滚动）-->
    <com.example.richtexteditor.ui.RichEditText
        android:id="@+id/richEditor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_editor"
        android:padding="14dp"
        android:gravity="top"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        android:inputType="textMultiLine|textCapSentences"
        android:hint="@string/hint_editor"
        android:textColorHint="@color/text_hint"
        android:scrollbars="vertical"
        android:overScrollMode="always" />

    <!-- ⑤ 状态栏 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="28dp"
        android:gravity="center"
        android:textSize="12sp"
        android:textColor="@color/accent_color"
        android:background="@android:color/white"
        android:paddingVertical="4dp"
        android:visibility="gone" />

</LinearLayout>
